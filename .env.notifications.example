# Notification Services Configuration

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@bellamoda.com

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Notification Settings
NOTIFICATIONS_ENABLED=true
AUTO_NOTIFICATIONS=true
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=5000

# WhatsApp Business API (Future)
# WHATSAPP_BUSINESS_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_VERIFY_TOKEN=

# Email Templates
EMAIL_TEMPLATE_BRAND_COLOR=#667eea
EMAIL_TEMPLATE_FONT_FAMILY='Segoe UI', Tahoma, Geneva, Verdana, sans-serif

# SMS Settings
SMS_MAX_LENGTH=160
SMS_INCLUDE_TRACKING_LINK=true

# Notification Channels by Status
NOTIFY_ON_PENDING=email
NOTIFY_ON_CONFIRMED=email,sms
NOTIFY_ON_PROCESSING=email
NOTIFY_ON_SHIPPED=email,sms
NOTIFY_ON_OUT_FOR_DELIVERY=email,sms
NOTIFY_ON_DELIVERED=email
NOTIFY_ON_CANCELLED=email,sms
NOTIFY_ON_RETURNED=email